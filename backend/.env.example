# Server settings
PORT=5000
NODE_ENV=development

# LLM Providers (At least one must be set to run mapping analyses)
# For Google Gemini (Recommended)
GEMINI_API_KEY=
# For OpenAI
OPENAI_API_KEY=

# Maximum CSV Upload Size (Default: 50MB)
MAX_FILE_SIZE_MB=50

# Storage Path (Used by file repository to save uploads/jobs/results)
STORAGE_DIR=./data
